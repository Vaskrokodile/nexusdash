{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/test.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/login.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/me.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/logout.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/clients/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/clients/[id].js",
      "use": "@vercel/node"
    },
    {
      "src": "api/users/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/users/[id].js",
      "use": "@vercel/node"
    },
    {
      "src": "api/dashboard/[id].js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/test", "dest": "/api/test.js" },
    { "src": "/api/auth/login", "dest": "/api/login.js" },
    { "src": "/api/auth/me", "dest": "/api/me.js" },
    { "src": "/api/auth/logout", "dest": "/api/logout.js" },
    { "src": "/api/clients", "dest": "/api/clients/index.js" },
    { "src": "/api/clients/.*", "dest": "/api/clients/[id].js" },
    { "src": "/api/users", "dest": "/api/users/index.js" },
    { "src": "/api/users/.*", "dest": "/api/users/[id].js" },
    { "src": "/api/dashboard/.*", "dest": "/api/dashboard/[id].js" },
    { "src": "/(.*)", "dest": "/client/dist/$1" }
  ]
}