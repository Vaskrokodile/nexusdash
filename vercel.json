{
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/auth/login", "dest": "/api/auth/login.js" },
    { "src": "/api/auth/me", "dest": "/api/auth/me.js" },
    { "src": "/api/auth/logout", "dest": "/api/auth/logout.js" },
    { "src": "/api/clients", "dest": "/api/clients/index.js" },
    { "src": "/api/clients/([^/]+)", "dest": "/api/clients/[id].js" },
    { "src": "/api/users", "dest": "/api/users/index.js" },
    { "src": "/api/users/([^/]+)", "dest": "/api/users/[id].js" },
    { "src": "/api/dashboard/([^/]+)", "dest": "/api/dashboard/[id].js" },
    { "src": "/(.*)", "dest": "/client/dist/$1" }
  ]
}